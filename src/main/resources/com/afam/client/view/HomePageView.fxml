<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.afam.client.controller.HomePageViewController">
    <VBox alignment="CENTER" spacing="20.0" styleClass="main-box" maxWidth="400" maxHeight="350">
        <Label styleClass="title-label" text="Home Page" textAlignment="CENTER" />
        <Button styleClass="button" fx:id="btnGestioneProfilo" mnemonicParsing="false" onAction="#handleGestioneProfilo" text="GESTIONE PROFILO" />
        <Button styleClass="button" fx:id="btnGestioneAccount" mnemonicParsing="false" onAction="#handleGestioneAccount" text="GESTIONE ACCOUNT" />
        <Button styleClass="button" fx:id="btnLogout" mnemonicParsing="false" onAction="#handleLogout" text="LOGOUT" />
    </VBox>
</StackPane>
