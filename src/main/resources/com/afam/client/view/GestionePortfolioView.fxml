<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.afam.client.controller.GestionePortfolioViewController">
    <VBox alignment="CENTER" spacing="15.0" styleClass="main-box" maxWidth="400" maxHeight="450">
        <Label styleClass="title-label" text="Gestione Portfolio" textAlignment="CENTER" />
        <Button styleClass="button" fx:id="btnVisualizza" mnemonicParsing="false" onAction="#handleVisualizza" text="VISUALIZZA PORTFOLIO" />
        <Button styleClass="button" fx:id="btnCreaRaccolta" mnemonicParsing="false" onAction="#handleCreaRaccolta" text="CREA RACCOLTA" />
        <Button styleClass="button" fx:id="btnAggiungiContenuto" mnemonicParsing="false" onAction="#handleAggiungiContenuto" text="AGGIUNGI CONTENUTO" />
        <Button styleClass="button" fx:id="btnAggiungiAllaRaccolta" mnemonicParsing="false" onAction="#handleAggiungiAllaRaccolta" text="AGGIUNGI ALLA RACCOLTA" />
        <Button styleClass="button" fx:id="btnIndietro" mnemonicParsing="false" onAction="#handleIndietro" text="INDIETRO" />
    </VBox>
</StackPane>
