<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.afam.client.controller.AuthPageViewController">
    <VBox alignment="CENTER" spacing="20.0" styleClass="main-box" maxWidth="400" maxHeight="450">
        <Label styleClass="title-label" text="Autenticati" textAlignment="CENTER" />
        <Button styleClass="button" fx:id="btnCreaAccount" mnemonicParsing="false" onAction="#handleCreaAccount" text="CREA ACCOUNT" />
        <Button styleClass="button" fx:id="btnAccedi" mnemonicParsing="false" onAction="#handleAccedi" text="ACCEDI" />
        <Button styleClass="button" fx:id="btnRecuperaPassword" mnemonicParsing="false" onAction="#handleRecuperaPassword" text="RECUPERA PASSWORD" />
        <Button styleClass="button" fx:id="btnSpid" mnemonicParsing="false" onAction="#handleSpid" text="ACCEDI CON SPID/eIDAS" />
        <Button styleClass="button" fx:id="btnOspite" mnemonicParsing="false" onAction="#handleOspite" text="ENTRA COME OSPITE" />
    </VBox>
</StackPane>
