<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.afam.client.boundary.gestisciportfolio.SelezioneRaccoltaBnd"
           styleClass="root" alignment="CENTER" prefWidth="440" prefHeight="240">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <VBox spacing="16" styleClass="card" maxWidth="400">
        <padding><Insets top="26" right="28" bottom="26" left="28"/></padding>

        <Label text="Aggiungi alla raccolta" styleClass="label-title"/>
        <Label fx:id="labelContenuto" styleClass="label-subtitle" wrapText="true"/>
        <ComboBox fx:id="comboRaccolta" maxWidth="Infinity"/>

        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 6 0 0 0;">
            <Button fx:id="btnConferma" text="AGGIUNGI ALLA RACCOLTA" onAction="#onConferma" styleClass="button"/>
        </HBox>
    </VBox>
</StackPane>
