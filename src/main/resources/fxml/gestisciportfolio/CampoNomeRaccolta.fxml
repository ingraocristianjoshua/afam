<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.afam.client.boundary.gestisciportfolio.CampoNomeRaccoltaBnd"
           styleClass="root"
           alignment="CENTER"
           minWidth="440" minHeight="240">

    <VBox styleClass="card" spacing="0" maxWidth="420"
          style="-fx-padding: 0; -fx-background-radius: 26; -fx-border-radius: 26;">

        <!-- Header viola -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: linear-gradient(to right, #4c1d95, #8b5cf6);
                     -fx-background-radius: 26 26 0 0; -fx-padding: 16 24 16 24;">
            <Label text="📁" style="-fx-font-size: 18px;"/>
            <Label fx:id="labelTitolo" text="Crea nuova raccolta"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>

        <!-- Corpo -->
        <VBox spacing="8" style="-fx-padding: 24 24 22 24;">
            <Label text="Nome raccolta"
                   style="-fx-text-fill: #a78bfa; -fx-font-size: 11px;
                          -fx-font-weight: bold; -fx-letter-spacing: 0.8px;"/>
            <TextField fx:id="fieldNome" styleClass="text-field"
                       promptText="Es. Composizioni 2024"/>
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 14 0 0 0;">
                <Button fx:id="btnAzione" text="CREA" onAction="#onAzione" styleClass="button"/>
            </HBox>
        </VBox>
    </VBox>

</StackPane>
