<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.autenticati.FormOTPBnd"
      spacing="0" prefWidth="380" styleClass="root" alignment="CENTER">

    <VBox spacing="16" styleClass="card" maxWidth="480">
        <padding><Insets top="30" right="36" bottom="30" left="36"/></padding>

        <Label text="Verifica OTP" styleClass="label-title"/>

        <Label fx:id="labelIstruzione" styleClass="label-subtitle" wrapText="true" maxWidth="300"/>

        <VBox spacing="4">
            <Label text="Codice OTP" styleClass="label"/>
            <TextField fx:id="campoOTP" promptText="123456" maxWidth="Infinity"
                       styleClass="text-field"
                       style="-fx-alignment: CENTER; -fx-font-size: 20px; -fx-letter-spacing: 6px;"/>
        </VBox>

        <Label fx:id="labelErrore" styleClass="label-error" wrapText="true"
               managed="false" visible="false"/>

        <Button text="INVIA NUOVO CODICE" onAction="#onInviaDiNuovo"
                maxWidth="Infinity" styleClass="button-secondary"/>

        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
            <Button fx:id="btnConferma" text="CONFERMA" onAction="#onVerifica" styleClass="button"/>
        </HBox>
    </VBox>
</VBox>
