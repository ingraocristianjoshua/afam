<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.autenticati.InserisciEmailBnd"
      alignment="CENTER" prefWidth="350" prefHeight="200"
      styleClass="dialog-pane">

    <!-- Header Panel -->
    <HBox alignment="CENTER" styleClass="header-panel" prefHeight="40">
        <Label text="Recupera Password" />
    </HBox>

    <!-- Content Panel -->
    <VBox alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS" styleClass="content">
        <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>

        <Label text="Inserisci la mail per recuperare la password" styleClass="label-subtitle" wrapText="true" maxWidth="320"/>

        <TextField fx:id="campoEmail" promptText="" maxWidth="Infinity"/>

        <Label fx:id="labelErrore" styleClass="label-error" wrapText="true" visible="false"/>

        <HBox alignment="CENTER" spacing="20" styleClass="button-bar">
            <Button text="ANNULLA" onAction="#onIndietro" prefWidth="120" />
            <Button text="INVIA CODICE" onAction="#onInviaOTP" prefWidth="120" />
        </HBox>
    </VBox>
</VBox>
