<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.afam.client.boundary.autenticati.AccediFormBnd"
           styleClass="root" alignment="CENTER"
           prefWidth="460" prefHeight="600">

    <VBox alignment="TOP_CENTER" spacing="0" styleClass="card" maxWidth="400"
          style="-fx-padding: 0; -fx-background-radius: 26; -fx-border-radius: 26;">

        <!-- Intestazione con icona -->
        <VBox alignment="CENTER" spacing="10"
              style="-fx-padding: 32 32 18 32;">
            <StackPane minWidth="64" minHeight="64" maxWidth="64" maxHeight="64"
                       style="-fx-background-color: linear-gradient(to bottom right,#8b5cf6,#4c1d95);
                              -fx-background-radius: 50;
                              -fx-effect: dropshadow(gaussian,rgba(139,92,246,0.5),16,0,0,4);">
                <Label text="🔐" style="-fx-font-size: 28px;"/>
            </StackPane>
            <Label text="Bentornato"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Accedi al tuo account AFAM"
                   style="-fx-font-size: 13px; -fx-text-fill: #a78bfa;"/>
        </VBox>

        <!-- Corpo -->
        <VBox spacing="14" style="-fx-padding: 4 32 28 32;">

            <VBox spacing="5">
                <Label text="E-MAIL"
                       style="-fx-text-fill: #a78bfa; -fx-font-size: 11px;
                              -fx-font-weight: bold; -fx-letter-spacing: 0.8px;"/>
                <TextField fx:id="campoEmail" promptText="mario.rossi@istituzione.it"
                           maxWidth="Infinity" styleClass="text-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="PASSWORD"
                       style="-fx-text-fill: #a78bfa; -fx-font-size: 11px;
                              -fx-font-weight: bold; -fx-letter-spacing: 0.8px;"/>
                <PasswordField fx:id="campoPassword" promptText="••••••••"
                               maxWidth="Infinity" styleClass="text-field"/>
            </VBox>

            <Label fx:id="labelErrore" styleClass="label-error" wrapText="true" maxWidth="320"
                   managed="false" visible="false"/>

            <Button fx:id="btnAccedi" text="ACCEDI" onAction="#onAccedi"
                    maxWidth="Infinity" styleClass="button"/>

            <!-- Link secondari -->
            <HBox alignment="CENTER" spacing="6" style="-fx-padding: 4 0 0 0;">
                <Button text="← Indietro" onAction="#onIndietro"
                        style="-fx-background-color: transparent; -fx-text-fill: #c4b5fd;
                               -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 4 8;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Password dimenticata?" onAction="#onRecuperaPassword"
                        style="-fx-background-color: transparent; -fx-text-fill: #a78bfa;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-cursor: hand; -fx-padding: 4 8;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
