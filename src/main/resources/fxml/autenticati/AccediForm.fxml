<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.autenticati.AccediFormBnd"
      spacing="0" prefWidth="420" styleClass="root">

    <VBox alignment="CENTER" spacing="16" styleClass="card">
        <padding><Insets top="40" right="50" bottom="40" left="50"/></padding>

        <Label text="Accedi" styleClass="label-title"/>
        <Label text="Inserisci le tue credenziali" styleClass="label-subtitle"/>

        <VBox spacing="4">
            <Label text="E-mail" styleClass="label"/>
            <TextField fx:id="campoEmail" promptText="mario.rossi@istituzione.it"
                       maxWidth="Infinity" styleClass="text-field"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Password" styleClass="label"/>
            <PasswordField fx:id="campoPassword" promptText="Password"
                           maxWidth="Infinity" styleClass="text-field"/>
        </VBox>

        <Label fx:id="labelErrore" styleClass="label-error" wrapText="true" maxWidth="320"
               managed="false" visible="false"/>

        <Label text="Password dimenticata?" styleClass="label-subtitle"/>
        <Button text="RECUPERA PASSWORD" onAction="#onRecuperaPassword"
                maxWidth="Infinity" styleClass="button-secondary"/>

        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 8 0 0 0;">
            <Button text="ANNULLA" onAction="#onIndietro" prefWidth="130" styleClass="button-secondary"/>
            <Button fx:id="btnAccedi" text="ACCEDI" onAction="#onAccedi" prefWidth="130" styleClass="button"/>
        </HBox>
    </VBox>
</VBox>
