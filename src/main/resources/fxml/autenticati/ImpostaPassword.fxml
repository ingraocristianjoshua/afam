<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.autenticati.ImpostaPasswordBnd"
      spacing="0" prefWidth="380" styleClass="root" alignment="CENTER">

    <VBox spacing="16" styleClass="card" maxWidth="480">
        <padding><Insets top="30" right="36" bottom="30" left="36"/></padding>

        <Label text="Recupera password" styleClass="label-title"/>
        <Label text="Inserisci la nuova password per il tuo account."
               styleClass="label-subtitle" wrapText="true"/>

        <VBox spacing="4">
            <Label text="Nuova password" styleClass="label"/>
            <PasswordField fx:id="campoNuovaPassword" promptText="Nuova password"
                           maxWidth="Infinity" styleClass="text-field"/>
        </VBox>

        <Label fx:id="labelErrore" styleClass="label-error" wrapText="true"
               managed="false" visible="false"/>

        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
            <Button text="CONFERMA" onAction="#onConferma" styleClass="button"/>
        </HBox>
    </VBox>
</VBox>
