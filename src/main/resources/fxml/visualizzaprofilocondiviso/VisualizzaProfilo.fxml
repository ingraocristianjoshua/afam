<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.afam.client.boundary.visualizzaprofilocondiviso.VisualizzaProfiloBnd"
            prefWidth="1000" prefHeight="720" styleClass="root">

    <top>
        <VBox styleClass="header-bar" spacing="4">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Profilo condiviso" styleClass="label-title"
                       style="-fx-text-fill: white; -fx-font-size: 20px;" HBox.hgrow="ALWAYS"/>
                <Button text="🔍 Cerca studenti" onAction="#onCercaStudenti"
                        styleClass="button-secondary"/>
            </HBox>
            <HBox spacing="20">
                <Label fx:id="labelNome" style="-fx-text-fill: #c4b5fd; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label fx:id="labelEmail" style="-fx-text-fill: #c4b5fd; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="boxPortfolio" spacing="10" styleClass="card">
                <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                <Label text="Portfolio pubblicati" styleClass="label-subtitle"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
