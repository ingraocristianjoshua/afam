<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.gestiscicondivisione.PannelloLinkBnd"
      spacing="14" prefWidth="460" styleClass="root">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <Label text="Genera link di condivisione"
           style="-fx-font-size:16px; -fx-font-weight:bold;"/>

    <Label text="Portfolio da condividere"/>
    <ComboBox fx:id="comboPortfolio" maxWidth="Infinity"/>

    <Label text="Visibilità"/>
    <ComboBox fx:id="comboVisibilita" maxWidth="Infinity"/>

    <CheckBox fx:id="checkAperto" text="Accessibile senza autenticazione (link aperto)"/>

    <Label text="Invia link via email (opzionale)"/>
    <TextField fx:id="fieldEmail" promptText="email@esempio.it"/>

    <Separator/>

    <Label text="Link generato:" styleClass="label-title"/>
    <Label fx:id="labelLink" text="–" wrapText="true"
           style="-fx-font-style:italic; -fx-text-fill:#2980b9;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCopia" text="Copia link" onAction="#onCopiaLink"/>
        <Button text="Genera"    onAction="#onGenera" styleClass="button-primary"/>
        <Button text="Chiudi"    onAction="#onChiudi"/>
    </HBox>
</VBox>
