<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.afam.client.boundary.gestiscicondivisione.GestioneCondivisioneBnd"
            prefWidth="1000" prefHeight="720"
            styleClass="root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header-bar">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label text="🔗" style="-fx-font-size: 18px;"/>
            <Label text="Gestisci Condivisione" styleClass="label-title" style="-fx-font-size: 20px;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

            <Label text="Condividi il tuo portfolio con il mondo"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <HBox spacing="20" alignment="CENTER">

                <!-- Genera link -->
                <VBox styleClass="card" spacing="12" alignment="CENTER_LEFT"
                      prefWidth="300" prefHeight="220">
                    <StackPane minWidth="54" minHeight="54" maxWidth="54" maxHeight="54"
                               style="-fx-background-color: linear-gradient(to bottom right,#00f2fe,#4facfe);
                                      -fx-background-radius: 50;
                                      -fx-effect: dropshadow(gaussian,rgba(79,172,254,0.45),12,0,0,3);">
                        <Label text="➕" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <Label text="Genera nuovo link"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Crea un link di condivisione per un tuo portfolio e invialo via email"
                           wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #c4b5fd;"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button text="Genera link  →" onAction="#onGeneraLink"
                            styleClass="button-primary" maxWidth="Infinity"/>
                </VBox>

                <!-- Visualizza link -->
                <VBox styleClass="card" spacing="12" alignment="CENTER_LEFT"
                      prefWidth="300" prefHeight="220">
                    <StackPane minWidth="54" minHeight="54" maxWidth="54" maxHeight="54"
                               style="-fx-background-color: linear-gradient(to bottom right,#8b5cf6,#6d28d9);
                                      -fx-background-radius: 50;
                                      -fx-effect: dropshadow(gaussian,rgba(139,92,246,0.45),12,0,0,3);">
                        <Label text="📋" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <Label text="I tuoi link"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Gestisci i link esistenti: scadenza, visibilità, invio email e revoca"
                           wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #c4b5fd;"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button text="Visualizza link  →" onAction="#onVisualizzaLink"
                            styleClass="button" maxWidth="Infinity"/>
                </VBox>

            </HBox>
        </VBox>
    </center>
</BorderPane>
