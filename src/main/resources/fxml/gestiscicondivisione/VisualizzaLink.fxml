<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.afam.client.boundary.gestiscicondivisione.VisualizzaLinkBnd"
            prefWidth="860" prefHeight="540"
            styleClass="root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-bar">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label text="Visualizza Link" styleClass="label-title"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="boxLinks" spacing="10" styleClass="card">
                <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
