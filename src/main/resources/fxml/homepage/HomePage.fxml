<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.afam.client.boundary.homepage.HomePageBnd"
            fx:id="root"
            prefWidth="960" prefHeight="760" styleClass="root">

    <!-- ═══ Header ═══════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="header-bar">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label text="Home" styleClass="label-title" style="-fx-font-size: 20px;"/>
            <Label text="&quot;Il primo passo indispensabile per ottenere dalla vita ciò che si vuole: decidere cosa si vuole&quot; — Ben Stein"
                   wrapText="true" HBox.hgrow="ALWAYS"
                   style="-fx-font-style: italic; -fx-font-size: 13px; -fx-text-fill: #c4b5fd;"/>
        </HBox>
    </top>

    <!-- ═══ Griglia sezioni ══════════════════════════════════════════════════ -->
    <center>
      <StackPane>
        <!-- Sfondo decorativo animato (emoji arte/musica, dietro le card) -->
        <Pane fx:id="bgDecor" mouseTransparent="true">
            <Label text="🎨" layoutX="46"  layoutY="90"  style="-fx-font-size: 50px; -fx-opacity: 0.13;" rotate="-12"/>
            <Label text="🎵" layoutX="110" layoutY="250" style="-fx-font-size: 34px; -fx-opacity: 0.12;" rotate="8"/>
            <Label text="🎹" layoutX="34"  layoutY="430" style="-fx-font-size: 46px; -fx-opacity: 0.12;" rotate="-6"/>
            <Label text="🎻" layoutX="100" layoutY="600" style="-fx-font-size: 40px; -fx-opacity: 0.12;" rotate="14"/>
            <Label text="🖌" layoutX="54"  layoutY="720" style="-fx-font-size: 34px; -fx-opacity: 0.13;" rotate="-10"/>
            <Label text="🎼" layoutX="900" layoutY="96"  style="-fx-font-size: 46px; -fx-opacity: 0.13;" rotate="10"/>
            <Label text="🎤" layoutX="932" layoutY="258" style="-fx-font-size: 36px; -fx-opacity: 0.12;" rotate="-8"/>
            <Label text="🥁" layoutX="868" layoutY="430" style="-fx-font-size: 46px; -fx-opacity: 0.12;" rotate="6"/>
            <Label text="🎷" layoutX="918" layoutY="600" style="-fx-font-size: 40px; -fx-opacity: 0.12;" rotate="-14"/>
            <Label text="🎭" layoutX="858" layoutY="720" style="-fx-font-size: 36px; -fx-opacity: 0.13;" rotate="12"/>
        </Pane>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="6">
                <padding><Insets top="26" right="36" bottom="26" left="36"/></padding>

                <GridPane hgap="20" vgap="20" alignment="CENTER">
                    <padding><Insets top="20"/></padding>

                    <!-- Account -->
                    <VBox styleClass="card" spacing="12" GridPane.columnIndex="0" GridPane.rowIndex="0"
                          prefWidth="300" prefHeight="210">
                        <StackPane minWidth="54" minHeight="54" maxWidth="54" maxHeight="54"
                                   style="-fx-background-color: linear-gradient(to bottom right,#8b5cf6,#6d28d9);
                                          -fx-background-radius: 50;
                                          -fx-effect: dropshadow(gaussian,rgba(139,92,246,0.45),12,0,0,3);">
                            <Label text="👤" style="-fx-font-size: 24px;"/>
                        </StackPane>
                        <Label text="Gestisci Account"
                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Modifica informazioni, password e validazioni" wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #c4b5fd;"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="Clicca" onAction="#onGestisciAccount"
                                styleClass="button" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Portfolio -->
                    <VBox styleClass="card" spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="0"
                          prefWidth="300" prefHeight="210">
                        <StackPane minWidth="54" minHeight="54" maxWidth="54" maxHeight="54"
                                   style="-fx-background-color: linear-gradient(to bottom right,#8b5cf6,#6d28d9);
                                          -fx-background-radius: 50;
                                          -fx-effect: dropshadow(gaussian,rgba(139,92,246,0.45),12,0,0,3);">
                            <Label text="🗂" style="-fx-font-size: 24px;"/>
                        </StackPane>
                        <Label text="Gestisci Portfolio"
                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Crea e organizza le tue opere in raccolte" wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #c4b5fd;"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="Clicca" onAction="#onGestisciPortfolio"
                                styleClass="button" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Contenuti -->
                    <VBox styleClass="card" spacing="12" GridPane.columnIndex="0" GridPane.rowIndex="1"
                          prefWidth="300" prefHeight="210">
                        <StackPane minWidth="54" minHeight="54" maxWidth="54" maxHeight="54"
                                   style="-fx-background-color: linear-gradient(to bottom right,#8b5cf6,#6d28d9);
                                          -fx-background-radius: 50;
                                          -fx-effect: dropshadow(gaussian,rgba(139,92,246,0.45),12,0,0,3);">
                            <Label text="📁" style="-fx-font-size: 24px;"/>
                        </StackPane>
                        <Label text="Gestisci Contenuti"
                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Carica file, gestisci metadati e visibilità" wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #c4b5fd;"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="Clicca" onAction="#onGestisciContenuti"
                                styleClass="button" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Condivisione -->
                    <VBox styleClass="card" spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="1"
                          prefWidth="300" prefHeight="210">
                        <StackPane minWidth="54" minHeight="54" maxWidth="54" maxHeight="54"
                                   style="-fx-background-color: linear-gradient(to bottom right,#8b5cf6,#6d28d9);
                                          -fx-background-radius: 50;
                                          -fx-effect: dropshadow(gaussian,rgba(139,92,246,0.45),12,0,0,3);">
                            <Label text="🔗" style="-fx-font-size: 24px;"/>
                        </StackPane>
                        <Label text="Gestisci Condivisione"
                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Genera link per condividere il tuo profilo" wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #c4b5fd;"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="Clicca" onAction="#onGestisciLink"
                                styleClass="button" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Profilo pubblico (a tutta larghezza) -->
                    <VBox styleClass="card" spacing="12" GridPane.columnIndex="0" GridPane.rowIndex="2"
                          GridPane.columnSpan="2" prefHeight="108">
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <StackPane minWidth="54" minHeight="54" maxWidth="54" maxHeight="54"
                                       style="-fx-background-color: linear-gradient(to bottom right,#00f2fe,#4facfe);
                                              -fx-background-radius: 50;
                                              -fx-effect: dropshadow(gaussian,rgba(79,172,254,0.45),12,0,0,3);">
                                <Label text="👁" style="-fx-font-size: 24px;"/>
                            </StackPane>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Visualizza Profilo Condiviso"
                                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Label text="Guarda come appare il tuo profilo agli ospiti e cerca altri studenti"
                                       wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #c4b5fd;"/>
                            </VBox>
                            <Button text="Clicca" onAction="#onVisualizzaProfilo"
                                    styleClass="button-primary"/>
                        </HBox>
                    </VBox>

                </GridPane>
            </VBox>
        </ScrollPane>
      </StackPane>
    </center>

</BorderPane>
