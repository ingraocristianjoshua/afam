<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.gestisciaccount.FormSelettore2FABnd"
      spacing="0" prefWidth="420" styleClass="root">

    <VBox spacing="14" styleClass="card">
        <padding><Insets top="30" right="36" bottom="30" left="36"/></padding>
        <Label text="Autenticazione a due fattori" styleClass="label-title"/>
        <Label fx:id="labelStato" styleClass="label-subtitle"/>
        <CheckBox fx:id="checkAbilita" text="Abilita autenticazione a due fattori"/>
        <VBox spacing="4">
            <Label text="Email associata" styleClass="label"/>
            <TextField fx:id="campoEmail" promptText="email@esempio.it" maxWidth="Infinity" styleClass="text-field"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Numero di telefono" styleClass="label"/>
            <TextField fx:id="campoNumero" promptText="+39 333 1234567" maxWidth="Infinity" styleClass="text-field"/>
        </VBox>
        <Label fx:id="labelErrore" styleClass="label-error" wrapText="true" maxWidth="340"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="ANNULLA" onAction="#onAnnulla" styleClass="button-secondary"/>
            <Button text="SALVA"   onAction="#onSalva"   styleClass="button-primary"/>
        </HBox>
    </VBox>
</VBox>
