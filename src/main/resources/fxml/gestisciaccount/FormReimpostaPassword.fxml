<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.gestisciaccount.FormReimpostaPasswordBnd"
      spacing="0" prefWidth="420" styleClass="root" alignment="CENTER">

    <VBox spacing="14" styleClass="card" maxWidth="480">
        <padding><Insets top="30" right="36" bottom="30" left="36"/></padding>
        <Label text="Imposta password" styleClass="label-title"/>
        <VBox spacing="4">
            <Label text="Password attuale" styleClass="label"/>
            <PasswordField fx:id="campoVecchia" promptText="Password corrente" maxWidth="Infinity" styleClass="text-field"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Nuova password" styleClass="label"/>
            <PasswordField fx:id="campoNuova" promptText="Nuova password" maxWidth="Infinity" styleClass="text-field"/>
        </VBox>
<Label fx:id="labelErrore" styleClass="label-error" wrapText="true" maxWidth="340"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="SALVA" onAction="#onConferma" styleClass="button-primary"/>
        </HBox>
    </VBox>
</VBox>
