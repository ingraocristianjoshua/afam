<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.gestisciaccount.FormModificaBnd"
      spacing="0" prefWidth="440" styleClass="root" alignment="CENTER">

    <VBox spacing="14" styleClass="card" maxWidth="480">
        <padding><Insets top="30" right="36" bottom="30" left="36"/></padding>

        <Label text="Modifica dati" styleClass="label-title"/>

        <VBox spacing="4">
            <Label text="Nome" styleClass="label"/>
            <TextField fx:id="campoNome" maxWidth="Infinity" styleClass="text-field"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Cognome" styleClass="label"/>
            <TextField fx:id="campoCognome" maxWidth="Infinity" styleClass="text-field"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Data di nascita" styleClass="label"/>
            <TextField fx:id="campoDataNascita" maxWidth="Infinity" editable="false" styleClass="text-field"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Email" styleClass="label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="campoEmail" maxWidth="Infinity" editable="false"
                           styleClass="text-field" HBox.hgrow="ALWAYS"/>
                <Button text="CAMBIA" onAction="#onCambiaEmail" styleClass="button-secondary"/>
            </HBox>
        </VBox>

        <Label fx:id="labelErrore" styleClass="label-error" wrapText="true" maxWidth="340"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="SALVA" onAction="#onSalva" styleClass="button-primary"/>
        </HBox>
    </VBox>
</VBox>
