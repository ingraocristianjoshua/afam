<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.gestiscicontenuti.CompilaFormBnd"
      spacing="14" prefWidth="420" styleClass="root">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <Label text="Compila form" style="-fx-font-size:16px; -fx-font-weight:bold;"/>

    <Label text="Titolo"/>
    <TextField fx:id="fieldTitolo" promptText="Titolo del contenuto"/>

    <Label text="File"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="labelFile" text="Nessun file selezionato"
               style="-fx-font-style:italic; -fx-text-fill:gray;" HBox.hgrow="ALWAYS"/>
        <Button text="Sfoglia…" onAction="#onSfoglia"/>
    </HBox>

    <Label text="Visibilità"/>
    <ComboBox fx:id="comboVisibilita" maxWidth="Infinity"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annulla" onAction="#onAnnulla"/>
        <Button text="Carica"  onAction="#onCarica" styleClass="button-primary"/>
    </HBox>
</VBox>
