<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.afam.client.boundary.gestiscicontenuti.CompilaFormBnd"
      spacing="0" prefWidth="460" styleClass="root">

    <VBox spacing="16" styleClass="card">
        <padding><Insets top="30" right="36" bottom="30" left="36"/></padding>

        <Label text="Carica contenuto" styleClass="label-title"/>

        <VBox spacing="4">
            <Label text="Titolo" styleClass="label"/>
            <TextField fx:id="fieldTitolo" promptText="Titolo del contenuto"
                       maxWidth="Infinity" styleClass="text-field"/>
        </VBox>

        <VBox spacing="4">
            <Label text="File" styleClass="label"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="labelFile" editable="false"
                           text="Nessun file selezionato"
                           styleClass="text-field" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="SFOGLIA…" onAction="#onSfoglia" styleClass="button-secondary"/>
            </HBox>
        </VBox>

        <VBox spacing="4">
            <Label text="Visibilità" styleClass="label"/>
            <ComboBox fx:id="comboVisibilita" maxWidth="Infinity"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="ANNULLA" onAction="#onAnnulla" styleClass="button-secondary"/>
            <Button text="CARICA"  onAction="#onCarica"  styleClass="button"/>
        </HBox>
    </VBox>
</VBox>
