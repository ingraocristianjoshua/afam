<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.afam.client.boundary.gestiscicontenuti.FormVisibilitaBnd"
           styleClass="root" alignment="CENTER" prefWidth="440" prefHeight="280">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <VBox spacing="16" styleClass="card" maxWidth="400">
        <padding><Insets top="26" right="28" bottom="26" left="28"/></padding>

        <Label text="Imposta visibilità contenuto" styleClass="label-title"/>
        <Label fx:id="labelContenuto" styleClass="label-subtitle" wrapText="true"/>

        <Label text="Visibilità"
               style="-fx-text-fill: #a78bfa; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        <ComboBox fx:id="comboVisibilita" maxWidth="Infinity"/>

        <Label fx:id="labelErrore" styleClass="label-error" wrapText="true"
               managed="false" visible="false"/>

        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 6 0 0 0;">
            <Button fx:id="btnSalva" text="CONFERMA" onAction="#onSalva" styleClass="button"/>
        </HBox>
    </VBox>
</StackPane>
